PORT=3001

# Upstream Scriptz-Api (proxy target) — same as Vite server.proxy['/api'].target in Scriptz-App-React
SCRIPTZ_API_BASE_URL=http://127.0.0.1:8000

# Browser API base (optional) — same idea as VITE_API_BASE_URL in the React app.
# - Leave UNSET: browser uses relative /api (empty base); Express proxies to SCRIPTZ_API_BASE_URL (recommended).
# - Set to e.g. http://127.0.0.1:8000: browser calls the API directly; proxy turns OFF — you must allow CORS for the admin origin on Scriptz-Api.
#SCRIPTZ_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Set to 0 to disable /api proxy even when SCRIPTZ_PUBLIC_API_BASE_URL is unset (uses SCRIPTZ_API_BASE_URL in the browser; needs CORS).
#SCRIPTZ_ADMIN_API_PROXY=0
